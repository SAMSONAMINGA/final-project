# ===== VERCEL DEPLOYMENT .env.local FILE =====
# Copy to .env.local and update with actual values
# Then commit to git (Vercel will read from GitHub)

# Backend API URL (change to your Render backend URL)
NEXT_PUBLIC_API_URL=https://floodguard-backend.onrender.com

# Mapbox token (optional - dark-v11 works without token)
# Get free token at https://mapbox.com/account/tokens/
NEXT_PUBLIC_MAPBOX_TOKEN=pk_test_your_token_here
