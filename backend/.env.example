# Database
DATABASE_URL=postgresql+asyncpg://floodguard:floodguard@localhost:5432/floodguard_ke
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_BROKER_URL=redis://localhost:6379/1

# JWT Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081,https://floodguard.example.com

# Africa's Talking
AFRICAS_TALKING_API_KEY=your_api_key_here
AFRICAS_TALKING_USERNAME=your_username_here

# NASA IMERG
NASA_BEARER_TOKEN=your_nasa_token_here
IMERG_BASE_URL=https://jsimpsonhttps.pps.eosdis.nasa.gov/imerg/gis/early/

# OpenWeather
OPENWEATHER_API_KEY=your_openweather_key_here

# Environment
ENV=development
DEBUG=True
LOG_LEVEL=INFO

# ML Model
MODEL_PATH=/app/models/gatv2_geoflood.onnx
EKF_CONFIG_PATH=/app/config/ekf_params.json

# Kenya Bounding Box (EPSG:4326)
KENYA_BBOX_WEST=33.9
KENYA_BBOX_SOUTH=-4.7
KENYA_BBOX_EAST=41.9
KENYA_BBOX_NORTH=5.0
